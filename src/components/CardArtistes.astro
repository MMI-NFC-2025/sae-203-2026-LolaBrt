---
import PbImage from "./PbImage.astro";

const artiste = Astro.props.artiste;
---

<div
  class="offre relative grid-cols-2 bg-white rounded-lg p-4 m-4 shadow-md hover:shadow-lg hover:-translate-y-1 transition-all cursor-pointer"
>
  <a
    class="absolute inset-0 z-0"
    href={`/artistes/${artiste.id}`}
    aria-label={`Voir plus sur ${artiste.nom_artiste}`}></a>

  <div>
    <PbImage record={artiste} recordImage={artiste.img_main_artiste[0]} />
  </div>

  <div>
    <strong class="text-blue-600 text-2xl"> {artiste.nom_artiste}</strong>
  </div>
</div>
