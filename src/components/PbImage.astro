---
import { Image } from "astro:assets";
import { getImageUrl } from "../../backend/backend.mjs";

const { record, recordImage } = Astro.props;

const imageURL = await getImageUrl(record, recordImage);
---

{
  imageURL && (
    <Image
      src={imageURL}
      alt={record.nom_scene || record.nom_artiste || "Image"}
      inferSize={true}
      class="w-full h-full object-cover object-center block"
    />
  )
}
