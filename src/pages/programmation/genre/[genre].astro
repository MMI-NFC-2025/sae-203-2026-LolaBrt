---
import Layout from "../../../layouts/Layout.astro";
import Hero from "../../../components/Hero.astro";
import { Picture } from "astro:assets";
import imgHero from "../../../assets/img/hero_programme.webp";
import CardArtistes from "../../../components/CardArtistes.astro";
import { artistesParGenre } from "../../../../backend/backend.mjs";

const genreParam = Astro.params.genre
  ? decodeURIComponent(Astro.params.genre)
  : "";
const artistes = await artistesParGenre(genreParam);
---

<Layout title={`Programmation - ${genreParam}`}>
  <Hero title="Programmation" showButton={false}>
    <Picture
      slot="image"
      src={imgHero}
      alt="feux d'artifice"
      layout="full-width"
      pictureAttributes={{ class: "object-cover " }}
    />
  </Hero>

  {
    artistes.length === 0 ? (
      <p>Aucun artiste trouvé pour ce genre.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 my-8">
        {artistes.map((artiste) => (
          <CardArtistes artiste={artiste} />
        ))}
      </div>
    )
  }
</Layout>
