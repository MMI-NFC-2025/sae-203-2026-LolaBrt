---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import { oneSceneID } from "../../../backend/backend.mjs";
import {allScenes} from "../../../backend/backend.mjs";
import PbImage from "../../components/PbImage.astro";
import CardArtistes from "../../components/CardArtistes.astro";
import CardScenes from "../../components/CardScenes.astro"

const id = Astro.params.id;
const scene = await oneSceneID(id);
const scenes = await allScenes();
import { allArtistsDate } from "../../../backend/backend.mjs";

let artist = await allArtistsDate();
---

<Layout
  title={scene.nom_scene}
  description={`Découvrez la ${scene.nom_scene}.`}
>
  <Hero showButton={false}>
    <PbImage
      slot="image"
      record={scene}
      recordImage={scene.img_scene}
      layout="full-width"
      pictureAttributes={{ class: "object-cover " }}
    />
  </Hero>

  <section class="bg-prim200 grille py-4">
    <div class="flex flex-col gap-1 col-start-5 col-span-3">
      <h3 class="col-span-3 col-start-4">{scene.nom_scene}</h3>
    </div>
  </section>

  <p class="mx-80 my-20">{scene.descr_scene}</p>

  <div class="mx-80 my-20">
    <PbImage slot="image" record={scene} recordImage={scene.loc_scene} />
  </div>

  <section class="bg-acc100">
    <h3 class="text-prim100 mx-16 pt-14">Au rendez-vous</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 px-8 py-4">
      {artist.map((artist) => <CardArtistes artiste={artist} />)}
    </div>
  </section>

  <section>
    <h3 class="text-prim500 mx-16 pt-14">D'un scène à l'autre</h3>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 py-10 px-8 mx-40">
      {scenes.map((scene) => <CardScenes scene={scene} />)}
    </div>
  </section>
</Layout>
